  <property name="windowTitle">
   <string>Quản lý điểm — Quản trị viên</string>
  </property>
  <property name="styleSheet">
   <string notr="true">QWidget {
  background: #f6f7f4;
  color: #1f2937;
  font-size: 14px;
}
QFrame#topBar {
  background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #25215a,stop:1 #3e2f89);
  border-radius: 10px 10px 0 0;
}
QFrame#navBar {
  background: #3a3286;
  border-radius: 0 0 10px 10px;
}
QLabel#lblBrand {
  color: #f8f7ff;
  font-size: 21px;
  font-weight: 700;
  background: transparent;
}
QLabel#lblAccount {
  color: #e9e7ff;
  font-weight: 600;
  background: transparent;
}

QPushButton {
  background: #ffffff;
  border: 1px solid #d4d4d8;
  border-radius: 10px;
  padding: 8px 12px;
  font-weight: 600;
}
QPushButton:hover { background: #fafafa; }

#btnTongQuan, #btnPhanQuyen, #btnSinhVien, #btnGiangVien, #btnMonHoc, #btnBaoCao {
  background: transparent;
  border: none;
  color: #e4e4ff;
  border-radius: 0;
  padding: 10px 16px;
}
#btnTongQuan {
  color: #ffffff;
  font-weight: 700;
  border-bottom: 2px solid #ffffff;
}
#btnTongQuan:hover, #btnPhanQuyen:hover, #btnSinhVien:hover, #btnGiangVien:hover, #btnMonHoc:hover, #btnBaoCao:hover {
  color: #ffffff;
}

QLineEdit, QComboBox, QListWidget {
  background: #ffffff;
  border: 1px solid #d4d4d8;
  border-radius: 10px;
  padding: 8px;
}
QTableWidget {
  background: #ffffff;
  border: 1px solid #d4d4d8;
  border-radius: 10px;
  gridline-color: #ececec;
  alternate-background-color: #fafafa;
}
QHeaderView::section {
  background: #eef2f7;
  color: #334155;
  border: none;
  border-bottom: 1px solid #dde3ea;
  padding: 8px;
  font-weight: 700;
}

QFrame#alertFrame {
  background: #fff8f8;
  border: 1px solid #f0c7c7;
  border-radius: 12px;
}
QLabel#lblAlert {
  color: #7f1d1d;
  font-weight: 600;
  padding: 4px 2px;
}

#cardTongTaiKhoan, #cardSinhVien, #cardGiangVien, #cardBiKhoa,
#cardBcTongSv, #cardBcTyLeDau, #cardBcGpaTb, #cardBcMonRot,
#cardLogTong, #cardLogOk, #cardLogFail, #cardLogLock, #cardLogScore {
  background: #ffffff;
  border: 1px solid #d4d4d8;
  border-radius: 12px;
  text-align: left;
  padding: 12px;
  font-weight: 700;
}
#lblPcNote {
  background: #eef2ff;
  border: 1px solid #c7d2fe;
  border-radius: 10px;
  padding: 9px;
  color: #3730a3;
}

#txtAccSearch {
  font-size: 15px;
  padding: 10px 12px;
}
#cbAccRole, #cbAccStatus, #cbAccKhoa {
  font-size: 15px;
  padding: 10px 12px;
}
#btnAccCreate, #btnAccImport {
  font-size: 16px;
  border-radius: 10px;
  padding: 10px 16px;
}
#pillAll, #pillAdmin, #pillGV, #pillSV, #pillLocked {
  background: #ffffff;
  border: 1px solid #c7c9d1;
  border-radius: 16px;
  padding: 6px 14px;
  font-weight: 600;
}
#pillAll { border-color: #9188d8; color: #3f3b85; }
#pillLocked { border-color: #e8b4b8; color: #8b1f2b; }
#tbAccounts {
  border-radius: 12px;
}
#tbAccounts QTableCornerButton::section {
  background: #eef2f7;
}</string>
